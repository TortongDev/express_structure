# Connect to Supabase via connection pooling
DATABASE_URL="SUPABASE_CONNECTION_STRING"
# Direct connection to the database. Used for migrations
DIRECT_URL="SUPABASE_CONNECTION_STRING_DIRECT"

EJS_PORT=3000
APP_PORT=4000
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Internal API secret — customer webapp server → backoffice API
INTERNAL_API_SECRET=CHANGE_ME

# ── Redis ──────────────────────────────────────────────────────────────────────
# แบบแยก (Remote / Managed Redis) — มี priority สูงกว่า
# REDIS_URL=redis://user:password@host:6379/0
# REDIS_URL=rediss://user:password@host:6380/0   ← TLS

# แบบรวมโปรเจกต์ (localhost) — ใช้เมื่อไม่ได้ set REDIS_URL
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0