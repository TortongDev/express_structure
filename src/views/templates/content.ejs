<!-- USERS SECTION -->
      <section id="users">
        <div class="d-flex justify-content-between mb-3">
          <h3>User Management</h3>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#userModal">
            Add User
          </button>
        </div>

        <table class="table table-bordered">
          <thead class="table-dark">
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1</td>
              <td>John Doe</td>
              <td>john@mail.com</td>
              <td>
                <button class="btn btn-sm btn-warning">Edit</button>
                <button class="btn btn-sm btn-danger">Delete</button>
              </td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- ORDERS SECTION -->
      <section id="orders" class="mt-5">
        <div class="d-flex justify-content-between mb-3">
          <h3>Order Management</h3>
          <button class="btn btn-primary">Add Order</button>
        </div>

        <table class="table table-striped">
          <thead class="table-dark">
            <tr>
              <th>ID</th>
              <th>Customer</th>
              <th>Total</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>#1001</td>
              <td>Alice</td>
              <td>$120</td>
              <td><span class="badge bg-success">Completed</span></td>
              <td>
                <button class="btn btn-sm btn-warning">Edit</button>
                <button class="btn btn-sm btn-danger">Delete</button>
              </td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- CONFIG SECTION -->
      <section id="config" class="mt-5">
        <h3>Shop Configuration</h3>

        <form class="mt-3">
          <div class="mb-3">
            <label class="form-label">Shop Name</label>
            <input type="text" class="form-control" placeholder="Enter shop name">
          </div>

          <div class="mb-3">
            <label class="form-label">Currency</label>
            <select class="form-select">
              <option>USD</option>
              <option>EUR</option>
              <option>THB</option>
            </select>
          </div>

          <button class="btn btn-success">Save Config</button>
        </form>
      </section>