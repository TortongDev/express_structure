<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login <%=locale%></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
  a {
    color: #007bff;
    text-align: center;
    text-decoration: none;
  }
  a + div {
    color: #007bff;
  }
</style>
</head>
<body class="bg-light">
<div class="container-fluid mt-3">
  <div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-8"></div>
    <div class="col-md-2 d-flex gap-2">
      <a href="?locale=en" class="<%=locale == 'en' ? 'bg-secondary' : '' %>">EN</a>
      <div> | </div>
      <a href="?locale=th" class="<%=locale == 'th' ? 'bg-secondary' : '' %>">ไทย</a>
    </div>
  </div>
</div>
<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card shadow p-4" style="width: 400px;">
    
    <h3 class="text-center mb-3"><%=text['title'] || ""%></h3>

    <form action="/login" method="POST">
      
      <!-- Username or Email -->
      <div class="mb-3">
        <label class="form-label"><%=text['username'] || ""%></label>
        <input 
          type="text" 
          name="identifier" 
          class="form-control" 
          placeholder="<%=text['placeholder_username']%>"
          required
        >
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label class="form-label"><%=text['password'] || ""%></label>
        <input 
          type="password" 
          name="password" 
          class="form-control" 
          placeholder="<%=text['placeholder_password']%>"
          required
        >
      </div>

      <!-- Remember Me -->
      <div class="mb-3 form-check">
        <input type="checkbox" name="remember" class="form-check-input" id="remember">
        <label class="form-check-label" for="remember"><%=text['remember_me'] || ""%></label>
      </div>

      <!-- Login Button -->
      <button type="submit" class="btn btn-primary w-100"><%=text['submit'] || ""%></button>

    </form>

  </div>
</div>

</body>
</html>
