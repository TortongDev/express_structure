<!DOCTYPE html>
<html lang="<%=locale%>">
<head>
  <meta charset="UTF-8">
  <title>Login <%=locale%></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    a { color: #007bff; text-align: center; text-decoration: none; }
    a + div { color: #007bff; }
  </style>
</head>
<body class="bg-light">

<div class="container-fluid mt-3">
  <div class="row">
    <div class="col-md-10"></div>
    <div class="col-md-2 d-flex gap-2">
      <a href="?locale=en&returnTo=<%=encodeURIComponent(returnTo)%>" class="<%=locale === 'en' ? 'bg-secondary text-white px-1' : ''%>">EN</a>
      <div> | </div>
      <a href="?locale=th&returnTo=<%=encodeURIComponent(returnTo)%>" class="<%=locale === 'th' ? 'bg-secondary text-white px-1' : ''%>">ไทย</a>
    </div>
  </div>
</div>

<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card shadow p-4" style="width: 400px;">

    <h3 class="text-center mb-3"><%=text['title'] || ''%></h3>

    <% if (error) { %>
    <div class="alert alert-danger py-2"><%=error%></div>
    <% } %>

    <form action="/auth/login?locale=<%=locale%>&returnTo=<%=encodeURIComponent(returnTo)%>" method="POST">

      <div class="mb-3">
        <label class="form-label"><%=text['username'] || ''%></label>
        <input
          type="text"
          name="username"
          class="form-control"
          placeholder="<%=text['placeholder_username']%>"
          required
          autocomplete="username"
          value="<%=user.username || ''%>"
        >
      </div>

      <div class="mb-3">
        <label class="form-label"><%=text['password'] || ''%></label>
        <input
          type="password"
          name="password"
          class="form-control"
          placeholder="<%=text['placeholder_password']%>"
          required
          autocomplete="current-password"
        >
      </div>
      <div class="mb-3">
        <button type="submit" class="btn btn-primary w-100"><%=text['submit'] || ''%></button>
      </div>
      <div class="wrapper-register text-center">
        <a href="/auth/register"><%=text['register']%></a>
      </div>
    </form>
  </div>
</div>

</body>
</html>
